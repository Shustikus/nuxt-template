## ❌ 7. Частые ошибки и как их избегать

### 7.1 Забытая обработка ошибок

```typescript
// ❌ Плохо
async function loadData() {
  const data = await fetch('/api/data');
  return data.json();
}

// ✅ Хорошо
async function loadData(): Promise<Data> {
  try {
    const response = await fetch('/api/data');

    if (!response.ok) {
      throw new Error(`HTTP ${response.status}`);
    }

    return await response.json();
  } catch (error) {
    console.error('Failed to load data:', error);
    throw error;
  }
}
```

### 7.2 Мутация параметров функции

```typescript
// ❌ Плохо
function addItem(items: Item[], newItem: Item): Item[] {
  items.push(newItem); // Мутация!
  return items;
}

// ✅ Хорошо
function addItem(items: Item[], newItem: Item): Item[] {
  return [...items, newItem];
}
```

### 7.3 Неправильная проверка на null/undefined

```typescript
// ❌ Плохо - проверяет все falsy значения
if (!value) {
  // 0, '', false тоже попадут сюда!
}

// ✅ Хорошо - явная проверка
if (value === null || value === undefined) {
  // Только null и undefined
}

// ✅ Или используйте опциональную цепочку
const name = user?.name ?? 'Default';
```

### 7.4 Забытый return в arrow functions

```typescript
// ❌ Плохо - забыли return
const doubled = numbers.map(n => {
  n * 2; // Вернёт undefined!
});

// ✅ Хорошо - явный return
const doubled = numbers.map(n => {
  return n * 2;
});

// ✅ Или неявный return
const doubled = numbers.map(n => n * 2);
```

### 7.5 Неправильное использование async/await

```typescript
// ❌ Плохо - лишние await в цикле
async function loadUsers(ids: number[]): Promise<User[]> {
  const users: User[] = [];
  for (const id of ids) {
    users.push(await fetchUser(id)); // Последовательно!
  }
  return users;
}

// ✅ Хорошо - параллельная загрузка
async function loadUsers(ids: number[]): Promise<User[]> {
  return Promise.all(ids.map(id => fetchUser(id)));
}
```

### 7.6 Игнорирование типов TypeScript

```typescript
// ❌ Плохо
const data = response.data as any;
// @ts-ignore
const result = someFunction();

// ✅ Хорошо - правильная типизация
interface ApiResponse {
  data: User[];
  total: number;
}

const response = await fetch<ApiResponse>('/api/users');
const data = response.data; // TypeScript знает тип
```

### 7.7 Неправильная работа с массивами

```typescript
// ❌ Плохо - изменение оригинального массива
const sortedItems = items.sort((a, b) => a.price - b.price);

// ✅ Хорошо - создание копии
const sortedItems = [...items].sort((a, b) => a.price - b.price);

// ❌ Плохо - использование индекса для удаления
items.splice(index, 1);

// ✅ Хорошо - filter создаёт новый массив
const newItems = items.filter((_, i) => i !== index);
// Или по условию
const newItems = items.filter(item => item.id !== targetId);
```

### 7.8 Забытая очистка ресурсов

```typescript
// ❌ Плохо - утечка памяти
function setupListener() {
  window.addEventListener('resize', handleResize);
}

// ✅ Хорошо - очистка при необходимости
function setupListener() {
  window.addEventListener('resize', handleResize);

  return () => {
    window.removeEventListener('resize', handleResize);
  };
}

// Использование
const cleanup = setupListener();
// Когда компонент удаляется
cleanup();
```

### 7.9 Неоптимальные условные выражения

```typescript
// ❌ Плохо
if (user.role === 'admin' || user.role === 'moderator' || user.role === 'superadmin') {
  // ...
}

// ✅ Хорошо
const privilegedRoles = ['admin', 'moderator', 'superadmin'] as const;
if (privilegedRoles.includes(user.role)) {
  // ...
}

// ❌ Плохо - вложенные тернарные операторы
const message = user
  ? user.isActive
    ? user.isPremium
      ? 'Premium Active User'
      : 'Active User'
    : 'Inactive User'
  : 'Guest';

// ✅ Хорошо - явная функция или switch
function getUserMessage(user: User | null): string {
  if (!user) return 'Guest';
  if (!user.isActive) return 'Inactive User';
  if (user.isPremium) return 'Premium Active User';
  return 'Active User';
}
```

