## 5. Тестирование с MSW

### 5.1 Конфигурация моков

```typescript
// mocks/handlers.ts
import { http, HttpResponse } from 'msw';

export const handlers = [
  // GET /api/users
  http.get('/api/users', () => {
    return HttpResponse.json([
      {
        id: 1,
        name: 'John Doe',
        email: 'john@example.com',
        role: 'user',
      },
      {
        id: 2,
        name: 'Jane Smith',
        email: 'jane@example.com',
        role: 'admin',
      },
    ]);
  }),

  // GET /api/users/:id с динамическим параметром
  http.get('/api/users/:id', async ({ params }) => {
    const { id } = params;

    // Имитация задержки сети
    await new Promise(resolve => setTimeout(resolve, 100));

    return HttpResponse.json({
      id: Number(id),
      name: `User ${id}`,
      email: `user${id}@example.com`,
      role: 'user',
    });
  }),

  // POST /api/users с валидацией
  http.post('/api/users', async ({ request }) => {
    const newUser = (await request.json()) as any;

    // Валидация данных
    if (!newUser.name || !newUser.email) {
      return HttpResponse.json({ error: 'Name and email are required' }, { status: 400 });
    }

    return HttpResponse.json(
      { ...newUser, id: Date.now(), createdAt: new Date().toISOString() },
      { status: 201 },
    );
  }),

  // Обработка ошибок
  http.get('/api/error', () => {
    return HttpResponse.json({ error: 'Internal server error' }, { status: 500 });
  }),

  // DELETE /api/users/:id
  http.delete('/api/users/:id', ({ params }) => {
    return HttpResponse.json({ message: `User ${params.id} deleted` }, { status: 200 });
  }),
];
```

**Настройка для браузера:**

```typescript
// mocks/browser.ts
import { setupWorker } from 'msw/browser';
import { handlers } from './handlers';

export const worker = setupWorker(...handlers);
```

**Настройка для Node.js (тесты):**

```typescript
// mocks/server.ts
import { setupServer } from 'msw/node';
import { handlers } from './handlers';

export const server = setupServer(...handlers);
```

> **Пояснение**: MSW (Mock Service Worker) перехватывает сетевые запросы на уровне Service Worker, позволяя тестировать без изменения кода приложения. Моки работают как в браузере, так и в тестах.

### 5.2 Интеграция с приложением

```typescript
// main.ts
async function bootstrapApplication() {
  // В development режиме запускаем MSW
  if (process.env.NODE_ENV === 'development') {
    const { worker } = await import('./mocks/browser');
    await worker.start({
      onUnhandledRequest: 'bypass', // Пропускать не замоканные запросы
      serviceWorker: {
        url: '/mockServiceWorker.js',
      },
    });
    console.log('🔶 MSW enabled');
  }

  // Инициализация приложения
  const app = new App();
  app.init();
}

bootstrapApplication().catch(console.error);
```

### 5.3 Тестирование с MSW

```typescript
// tests/user-service.test.ts
import { describe, it, expect, beforeAll, afterEach, afterAll } from 'vitest';
import { server } from '../mocks/server';
import { http, HttpResponse } from 'msw';
import { UserService } from '../services/user-service';

describe('UserService', () => {
  const userService = new UserService();

  // Запуск MSW перед всеми тестами
  beforeAll(() => server.listen());

  // Сброс handlers после каждого теста
  afterEach(() => server.resetHandlers());

  // Остановка MSW после всех тестов
  afterAll(() => server.close());

  it('should fetch users successfully', async () => {
    const users = await userService.getUsers();

    expect(users).toHaveLength(2);
    expect(users[0].name).toBe('John Doe');
    expect(users[0].email).toBe('john@example.com');
  });

  it('should handle API errors', async () => {
    // Переопределяем handler для конкретного теста
    server.use(
      http.get('/api/users', () => {
        return HttpResponse.json({ error: 'Service unavailable' }, { status: 503 });
      }),
    );

    await expect(userService.getUsers()).rejects.toThrow('Service unavailable');
  });

  it('should create user with valid data', async () => {
    const newUser = {
      name: 'Test User',
      email: 'test@example.com',
    };

    const createdUser = await userService.createUser(newUser);

    expect(createdUser.id).toBeDefined();
    expect(createdUser.name).toBe(newUser.name);
    expect(createdUser.email).toBe(newUser.email);
  });

  it('should reject invalid user data', async () => {
    const invalidUser = { name: '', email: '' };

    await expect(userService.createUser(invalidUser)).rejects.toThrow(
      'Name and email are required',
    );
  });

  it('should delete user', async () => {
    const result = await userService.deleteUser(1);

    expect(result.message).toContain('deleted');
  });
});
```

> **Пояснение**: MSW позволяет тестировать реальные HTTP-запросы без моков fetch/axios. Тесты получаются ближе к реальному сценарию использования и легче поддерживаются.

