## 6. Best Practices

### 6.1 Иммутабельность

```typescript
// ✅ Хорошо - создание новых объектов
const updateUser = (users: User[], updatedUser: User): User[] => {
  return users.map(user => (user.id === updatedUser.id ? updatedUser : user));
};

const addProduct = (cart: CartItem[], product: Product): CartItem[] => {
  return [...cart, { ...product, quantity: 1 }];
};

const removeProduct = (cart: CartItem[], productId: number): CartItem[] => {
  return cart.filter(item => item.id !== productId);
};

// ❌ Плохо - мутация исходных данных
const updateUser = (users: User[], updatedUser: User): void => {
  const user = users.find(u => u.id === updatedUser.id);
  if (user) {
    Object.assign(user, updatedUser); // Мутация!
  }
};

const addProduct = (cart: CartItem[], product: Product): void => {
  cart.push({ ...product, quantity: 1 }); // Мутация!
};
```

> **Пояснение**: иммутабельность предотвращает неожиданные изменения данных и упрощает отладку. Новые объекты явно показывают где происходят изменения и позволяют легко откатывать состояние.

### 6.2 Деструктуризация

```typescript
// ✅ Хорошо - деструктуризация параметров
function UserProfile({ user, onUpdate, isLoading }: UserProfileProps) {
  const { name, email, avatar } = user;

  return `
    <div class="user-profile">
      <img src="${avatar}" alt="${name}" />
      <h2>${name}</h2>
      <p>${email}</p>
      ${isLoading ? '<span>Updating...</span>' : ''}
    </div>
  `;
}

// ✅ Деструктуризация с значениями по умолчанию
function createUser({ name, email, role = 'user', active = true }: CreateUserDto): User {
  return {
    id: Date.now(),
    name,
    email,
    role,
    active,
    createdAt: new Date(),
  };
}

// ✅ Деструктуризация массивов
const [first, second, ...rest] = numbers;
const [error, setError] = useState<string | null>(null);

// ❌ Плохо - многократное обращение к свойствам
function UserProfile(props: UserProfileProps) {
  return `
    <div>
      <h2>${props.user.name}</h2>
      <p>${props.user.email}</p>
    </div>
  `;
}
```

> **Пояснение**: деструктуризация делает код компактнее и яснее показывает какие именно свойства используются. Это особенно полезно для объектов с множеством полей.

### 6.3 Опциональная цепочка и нулевое слияние

```typescript
// ✅ Хорошо - опциональная цепочка
const userName = user?.profile?.name ?? 'Anonymous';
const apiUrl = config?.api?.baseUrl ?? 'http://localhost:3000';
const itemCount = cart?.items?.length ?? 0;

// ✅ Безопасный вызов методов
const result = obj?.method?.();
const value = array?.[0]?.property;

// ✅ Нулевое слияние для значений по умолчанию
const port = process.env.PORT ?? 3000;
const timeout = options.timeout ?? 5000;

// ❌ Плохо - многословно и менее читаемо
const userName =
  user && user.profile && user.profile.name ? user.profile.name : 'Anonymous';

// ❌ Проблема с falsy значениями
const port = process.env.PORT || 3000; // 0 будет заменен на 3000!
const timeout = options.timeout || 5000; // 0 будет заменен на 5000!
```

> **Пояснение**: `?.` безопасно обращается к свойствам, которые могут не существовать. `??` проверяет именно null/undefined, не затрагивая другие falsy значения (0, '', false).

### 6.4 Async/Await вместо Promise chains

```typescript
// ✅ Хорошо - последовательные операции
async function processUser(id: number): Promise<void> {
  const user = await fetchUser(id);
  const profile = await fetchProfile(user.profileId);
  const settings = await fetchSettings(profile.settingsId);

  await updateUI(user, profile, settings);
}

// ✅ Параллельные операции
async function loadDashboard(): Promise<Dashboard> {
  const [user, stats, notifications] = await Promise.all([
    fetchUser(),
    fetchStats(),
    fetchNotifications(),
  ]);

  return { user, stats, notifications };
}

// ❌ Плохо - Promise chains менее читаемы
function processUser(id: number): Promise<void> {
  return fetchUser(id)
    .then(user => fetchProfile(user.profileId))
    .then(profile => fetchSettings(profile.settingsId))
    .then(settings => updateUI(settings));
}
```

### 6.5 Типизация и type guards

```typescript
// ✅ Хорошо - type guards для проверки типов
function isApiError(error: unknown): error is ApiError {
  return error instanceof ApiError;
}

function isUser(data: unknown): data is User {
  return typeof data === 'object' && data !== null && 'id' in data && 'email' in data;
}

// Использование
try {
  await someApiCall();
} catch (error) {
  if (isApiError(error)) {
    console.error(`API Error ${error.statusCode}: ${error.message}`);
  } else {
    console.error('Unknown error:', error);
  }
}

// ✅ Discriminated unions
type LoadingState = { status: 'loading' };
type SuccessState<T> = { status: 'success'; data: T };
type ErrorState = { status: 'error'; error: string };

type AsyncState<T> = LoadingState | SuccessState<T> | ErrorState;

function renderState<T>(state: AsyncState<T>): string {
  switch (state.status) {
    case 'loading':
      return '<div>Loading...</div>';
    case 'success':
      return `<div>${state.data}</div>`;
    case 'error':
      return `<div class="error">${state.error}</div>`;
  }
}
```

