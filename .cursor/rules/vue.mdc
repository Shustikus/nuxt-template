## 4. Структура проекта (Vanilla JS/TS)

### 4.1 Базовая структура

```
src/
├── components/          # Переиспользуемые UI компоненты
│   ├── ui/             # Базовые компоненты (Button, Input, Modal)
│   ├── forms/          # Специфичные компоненты форм
│   └── layout/         # Компоненты layout (Header, Sidebar)
├── modules/            # Бизнес-модули приложения
│   ├── auth/           # Модуль авторизации
│   │   ├── index.ts    # Публичный API модуля
│   │   ├── types.ts    # Типы модуля
│   │   ├── api.ts      # API вызовы
│   │   └── components/ # Компоненты модуля
│   ├── catalog/        # Модуль каталога
│   └── cart/           # Модуль корзины
├── services/           # Внешние API и сервисы
│   ├── api-client.ts   # Базовый HTTP клиент
│   ├── user-service.ts
│   └── product-service.ts
├── utils/              # Вспомогательные функции
│   ├── helpers.ts      # Общие утилиты
│   ├── formatters.ts   # Форматирование данных
│   └── validators.ts   # Валидация
├── types/              # Глобальные TypeScript типы
│   ├── api.ts          # Типы API
│   ├── common.ts       # Общие типы
│   └── index.ts        # Реэкспорт
├── styles/             # Глобальные стили
│   ├── base.scss       # Базовые стили
│   ├── variables.scss  # CSS переменные
│   └── mixins.scss     # SCSS миксины
└── main.ts             # Точка входа
```

> **Пояснение**: модульная структура группирует код по функциональности, а не по типу файлов. Это упрощает навигацию и позволяет легко удалять или переносить целые модули.

### 4.2 Модульная архитектура

**Определение типов модуля:**

```typescript
// modules/catalog/types.ts
export interface Product {
  id: number;
  name: string;
  price: number;
  category: string;
}

export interface CatalogState {
  products: Product[];
  loading: boolean;
  error: string | null;
  filters: ProductFilters;
}

export interface ProductFilters {
  category?: string;
  priceRange?: { min: number; max: number };
  searchQuery?: string;
}
```

**API слой модуля:**

```typescript
// modules/catalog/api.ts
import { Product, ProductFilters } from './types';

export class CatalogApi {
  private baseUrl = '/api';

  async getProducts(filters?: ProductFilters): Promise<Product[]> {
    const params = new URLSearchParams();

    if (filters?.category) {
      params.append('category', filters.category);
    }
    if (filters?.searchQuery) {
      params.append('search', filters.searchQuery);
    }
    if (filters?.priceRange) {
      params.append('minPrice', filters.priceRange.min.toString());
      params.append('maxPrice', filters.priceRange.max.toString());
    }

    const response = await fetch(`${this.baseUrl}/products?${params}`);
    if (!response.ok) {
      throw new Error('Failed to fetch products');
    }

    return response.json();
  }

  async getProduct(id: number): Promise<Product> {
    const response = await fetch(`${this.baseUrl}/products/${id}`);
    if (!response.ok) {
      throw new Error('Failed to fetch product');
    }

    return response.json();
  }
}
```

**Основной класс модуля:**

```typescript
// modules/catalog/index.ts
import { CatalogApi } from './api';
import { CatalogState, Product, ProductFilters } from './types';

export class CatalogModule {
  private state: CatalogState = {
    products: [],
    loading: false,
    error: null,
    filters: {},
  };

  private api: CatalogApi;
  private container: HTMLElement;

  constructor(container: HTMLElement) {
    this.container = container;
    this.api = new CatalogApi();
    this.init();
  }

  private init(): void {
    this.render();
    this.loadProducts();
  }

  async loadProducts(filters?: ProductFilters): Promise<void> {
    this.setState({ loading: true, error: null });

    try {
      const products = await this.api.getProducts(filters);
      this.setState({ products, loading: false });
    } catch (error) {
      this.setState({
        error: error instanceof Error ? error.message : 'Unknown error',
        loading: false,
      });
    }
  }

  private setState(updates: Partial<CatalogState>): void {
    this.state = { ...this.state, ...updates };
    this.render();
  }

  private render(): void {
    if (this.state.loading) {
      this.container.innerHTML = '<div class="loading">Loading...</div>';
    } else if (this.state.error) {
      this.container.innerHTML = `<div class="error">${this.state.error}</div>`;
    } else {
      this.container.innerHTML = this.renderProducts();
    }
  }

  private renderProducts(): string {
    return `
      <div class="catalog">
        ${this.state.products
          .map(
            product => `
          <div class="product-card" data-id="${product.id}">
            <h3>${product.name}</h3>
            <p class="price">$${product.price}</p>
            <button class="add-to-cart">Add to Cart</button>
          </div>
        `,
          )
          .join('')}
      </div>
    `;
  }
}
```

> **Пояснение**: каждый модуль - это самодостаточная единица с собственным состоянием, API и UI. Это позволяет разрабатывать и тестировать модули изолированно.

