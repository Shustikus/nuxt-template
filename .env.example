# ============================================
# Переменные окружения Nuxt template
# Скопируйте в .env и заполните значениями:
#   cp .env.example .env
# ============================================

# --- Серверные (не попадают в клиентский бандл) ---

# Опционально: переопределить origin бэкенда (Docker, staging, отдельный API).
# По умолчанию: dev → http://localhost:8080, prod → origin текущего запроса.
# NUXT_API_BASE_URL=

# --- Публичные (доступны на клиенте и сервере) ---

# Опционально: canonical/OG при сборке (по умолчанию https://example.com).
# Nitro-прокси в prod берёт origin из текущего запроса — env не нужен.
# NUXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Docker Compose (docker-compose.yaml) ---

HOST=0.0.0.0
PORT=3000
STORYBOOK_PORT=6006
NODE_ENV=production
