{
	"name": "nuxt-template",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "nuxt build",
		"analyze": "ANALYZE=1 nuxt build",
		"start": "nuxt start",
		"dev": "nuxt dev",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"prepare": "husky",
		"typecheck": "nuxt prepare && vue-tsc -p .nuxt/tsconfig.json --noEmit",
		"test": "npm run test:unit",
		"test:unit": "vitest --project unit",
		"test:unit:run": "vitest run --project unit",
		"test:e2e": "vitest run --project e2e",
		"test:e2e:install": "playwright install chromium",
		"test:storybook": "vitest run --project storybook",
		"test:coverage": "vitest run --project unit --project server --coverage",
		"test:ci": "VITEST_MSW_UNHANDLED=error vitest run --project unit --project server --coverage",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"ci": "npm run lint && npm run typecheck && npm run test:ci",
		"ci:e2e": "npm run test:e2e:install && NUXT_E2E_HOST=http://localhost:3000 npm run test:e2e",
		"check": "npm run lint && npm run typecheck && npm run test:coverage"
	},
	"dependencies": {
		"@nuxtjs/seo": "5.1.3",
		"@pinia/nuxt": "0.11.3",
		"nuxt": "4.4.7",
		"vue": "3.5.35",
		"vue-router": "5.1.0"
	},
	"devDependencies": {
		"@iconify-json/mdi": "^1.2.3",
		"@nuxt/icon": "2.2.3",
		"@nuxt/test-utils": "4.0.3",
		"@storybook/addon-a11y": "10.4.2",
		"@storybook/addon-docs": "10.4.2",
		"@storybook/addon-links": "10.4.2",
		"@storybook/addon-vitest": "10.4.2",
		"@storybook/vue3": "10.4.2",
		"@storybook/vue3-vite": "10.4.2",
		"@types/node": "^25.9.1",
		"@vitejs/plugin-vue": "6.0.7",
		"@vitest/browser-playwright": "4.1.8",
		"@vitest/coverage-v8": "4.1.8",
		"@vue/eslint-config-prettier": "10.2.0",
		"@vue/eslint-config-typescript": "14.7.0",
		"@vue/test-utils": "2.4.11",
		"eslint": "10.4.1",
		"eslint-plugin-vue": "10.9.2",
		"husky": "^9.1.7",
		"jsdom": "29.1.1",
		"lint-staged": "^17.0.7",
		"msw": "^2.14.6",
		"playwright": "1.60.0",
		"prettier": "3.8.3",
		"rollup-plugin-visualizer": "^7.0.1",
		"storybook": "10.4.2",
		"typescript": "6.0.3",
		"vitest": "4.1.8",
		"vue-tsc": "3.3.4"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	}
}
